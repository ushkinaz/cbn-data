# Global defaults for all data
/data/*
  Access-Control-Allow-Origin: *
  X-Content-Type-Options: nosniff
  Timing-Allow-Origin: *
  Referrer-Policy: strict-origin-when-cross-origin

# 1. Immutable versioned data (Force long cache)
/data/2*
  Cache-Control: public, max-age=31536000, immutable

/data/v*/*
  Cache-Control: public, max-age=31536000, immutable

# 2. Pre-compressed 'latest' data
# We MUST tell the browser this is gzipped data
/data/latest.gz/*
  Content-Encoding: gzip
  Content-Type: application/json
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# 3. Standard 'latest' and Registry files
/data/latest/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/builds.json
  Cache-Control: public, max-age=60, stale-while-revalidate=43200

/latest-build.json
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# 4. Prevent indexing of raw JSON data
/data/*.json
  X-Robots-Tag: noindex
