# Global defaults for all data
/data/*
  Access-Control-Allow-Origin: *
  X-Content-Type-Options: nosniff
  Timing-Allow-Origin: *
  Referrer-Policy: strict-origin-when-cross-origin

/data/2*
  Cache-Control: public, max-age=31536000, immutable

/data/v*/*
  Cache-Control: public, max-age=31536000, immutable

/builds.json
  Cache-Control: public, max-age=60, stale-while-revalidate=43200
  X-Robots-Tag: noindex

/data/data/2025-08-20/all.json
  Content-Encoding: br
  Content-Type: application/json
  Content-Length: 2040143
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400, no-transform

# 4. Prevent indexing of raw JSON data
/data/*.json
  X-Robots-Tag: noindex
