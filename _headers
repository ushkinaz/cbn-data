# If a path matches more than one rule, and headers are defined in multiple rules, multiple headers are added.
# That means we have to make sure that only one Cache-Control is applied ever - usually in the most specific rule.

/data/*.webp
  Access-Control-Allow-Origin: *
  X-Content-Type-Options: nosniff
  X-Robots-Tag: noindex

/data/*.json
  Access-Control-Allow-Origin: *
  Referrer-Policy: strict-origin-when-cross-origin
  X-Content-Type-Options: nosniff
  X-Robots-Tag: noindex

/builds.json
  Access-Control-Allow-Origin: *
  Referrer-Policy: strict-origin-when-cross-origin
  Cache-Control: public, max-age=10800, stale-while-revalidate=10800
  X-Content-Type-Options: nosniff
  X-Robots-Tag: noindex

# .json files are precompressed
/data/*.json
  Content-Encoding: br
  Content-Type: application/json
  Vary: Accept-Encoding

/data/v*.json
  Cache-Control: public, max-age=2592000, immutable, no-transform

/data/20*.json
  Cache-Control: public, max-age=2592000, immutable, no-transform

# 3 Hours
/data/nightly/*
  Cache-Control: public, max-age=10800, no-transform

# 1 day
/data/stable/*
  Cache-Control: public, max-age=86400, no-transform
